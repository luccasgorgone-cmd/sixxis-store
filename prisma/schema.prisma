generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Cliente {
  id               String               @id @default(cuid())
  nome             String
  email            String               @unique
  senha            String
  cpf              String?              @unique
  telefone         String?
  erpClienteId     String?              @unique
  createdAt        DateTime             @default(now())
  bloqueado        Boolean              @default(false)
  motivoBloqueio   String?
  bloqueadoEm      DateTime?
  cashbackSaldo    Float                @default(0)
  totalGasto       Float                @default(0)
  totalPedidos     Int                  @default(0)
  ultimaCompra     DateTime?
  carrinhoAbandon  Json?
  // Dados demográficos
  dataNascimento   DateTime?
  genero           String?
  avatar           String?
  avatarGradiente  String?              @default("tiffany")
  notifEmail       Boolean              @default(true)
  notifWhatsapp    Boolean              @default(false)
  avaliacoes           Avaliacao[]
  bloqueios            BloqueioFraude[]
  carrinho             Carrinho?
  cashback             CashbackTransacao[]
  cupomUsos            CupomUso[]
  enderecos            Endereco[]
  historicoPontos      HistoricoPontos[]
  pedidos              Pedido[]
  pontos               PontosCliente?
  campanhasDestinatario CampanhaDestinatario[]
}


model Endereco {
  id          String   @id @default(cuid())
  clienteId   String
  cep         String
  logradouro  String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String   @db.Char(2)
  principal   Boolean  @default(false)
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  pedidos     Pedido[]

  @@index([clienteId])
}

model Produto {
  id               String            @id @default(cuid())
  erpProdutoId     String            @unique
  nome             String
  slug             String            @unique
  descricao        String?           @db.Text
  preco            Decimal           @db.Decimal(10, 2)
  precoPromocional Decimal?          @db.Decimal(10, 2)
  imagens          Json
  estoque          Int               @default(0)
  categoria        String
  modelo           String?
  ativo            Boolean           @default(true)
  createdAt        DateTime          @default(now())
  sku              String?           @unique
  temVariacoes     Boolean           @default(false)
  videoUrl         String?           @default("")
  especificacoes   Json?
  faqs             Json?
  imagensPorVariacao Json?
  vendidos            Int               @default(0)
  mediaAvaliacoes     Float             @default(0)
  totalAvaliacoes     Int               @default(0)
  avaliacoes       Avaliacao[]
  itensCarrinho    ItemCarrinho[]
  itensPedido      ItemPedido[]
  listaEspera      ListaEspera[]
  destaques        ProdutoDestaque[]
  variacoes        VariacaoProduto[]

  @@index([categoria])
  @@index([slug])
  @@index([ativo])
}

model Pedido {
  id             String       @id @default(cuid())
  clienteId      String
  status         String       @default("pendente")
  total          Decimal      @db.Decimal(10, 2)
  frete          Decimal      @db.Decimal(10, 2)
  formaPagamento String
  mpPaymentId    String?
  enderecoId     String
  erpPedidoId    String?      @unique
  createdAt      DateTime     @default(now())
  codigoRastreio String?
  cupomCodigo    String?
  desconto       Decimal      @default(0.00) @db.Decimal(10, 2)
  itens          ItemPedido[]
  cliente        Cliente      @relation(fields: [clienteId], references: [id])
  endereco       Endereco     @relation(fields: [enderecoId], references: [id])

  @@index([clienteId])
  @@index([status])
  @@index([enderecoId], map: "Pedido_enderecoId_fkey")
}

model ItemPedido {
  id            String  @id @default(cuid())
  pedidoId      String
  produtoId     String
  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
  variacaoId    String?
  variacaoNome  String?
  pedido        Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto       Produto @relation(fields: [produtoId], references: [id])

  @@index([pedidoId])
  @@index([produtoId], map: "ItemPedido_produtoId_fkey")
}

model Carrinho {
  id        String         @id @default(cuid())
  clienteId String?        @unique
  sessionId String?        @unique
  createdAt DateTime       @default(now())
  cliente   Cliente?       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  itens     ItemCarrinho[]

  @@index([sessionId])
}

model ItemCarrinho {
  id         String   @id @default(cuid())
  carrinhoId String
  produtoId  String
  quantidade Int
  carrinho   Carrinho @relation(fields: [carrinhoId], references: [id], onDelete: Cascade)
  produto    Produto  @relation(fields: [produtoId], references: [id])

  @@unique([carrinhoId, produtoId])
  @@index([produtoId], map: "ItemCarrinho_produtoId_fkey")
}

model Avaliacao {
  id          String          @id @default(cuid())
  produtoId   String
  clienteId   String?
  nomeAutor   String          @default("")
  emailAutor  String?
  nota        Int
  titulo      String?
  comentario  String?         @db.Text
  aprovada    Boolean         @default(false)
  destaque    Boolean         @default(false)
  ordem       Int             @default(0)
  resposta    String?         @db.Text
  respostaEm  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  fotos       AvaliacaoFoto[]
  cliente     Cliente?        @relation(fields: [clienteId], references: [id])
  produto     Produto         @relation(fields: [produtoId], references: [id])

  @@index([clienteId], map: "Avaliacao_clienteId_fkey")
  @@index([produtoId, aprovada])
}

model AvaliacaoFoto {
  id          String    @id @default(cuid())
  avaliacaoId String
  url         String
  createdAt   DateTime  @default(now())
  avaliacao   Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)

  @@index([avaliacaoId])
}

model Banner {
  id        String   @id @default(cuid())
  imagem    String
  titulo    String?
  subtitulo String?
  link      String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  tempoCads Int      @default(5)
  createdAt DateTime @default(now())
}

model Configuracao {
  id        String   @id @default(cuid())
  chave     String   @unique
  valor     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Cupom {
  id             String     @id @default(cuid())
  codigo         String     @unique
  tipo           String     // "PERCENTUAL" | "VALOR_FIXO" | "FRETE_GRATIS"
  valor          Float
  usoMaximo      Int?
  totalUsos      Int        @default(0)
  pedidoMinimo   Float      @default(0)
  validade       DateTime?
  ativo          Boolean    @default(true)
  descricao      String?
  primeiraCompra Boolean    @default(false)
  usos           CupomUso[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model CupomUso {
  id            String    @id @default(cuid())
  cupomId       String
  cupom         Cupom     @relation(fields: [cupomId], references: [id], onDelete: Cascade)
  clienteId     String?
  cliente       Cliente?  @relation(fields: [clienteId], references: [id])
  pedidoId      String?
  emailCliente  String?
  nomeCliente   String?
  valorDesconto Float     @default(0)
  valorPedido   Float     @default(0)
  usadoEm       DateTime  @default(now())

  @@index([cupomId])
  @@index([clienteId])
}

model HistoricoPontos {
  id        String   @id @default(cuid())
  clienteId String
  pontos    Int
  tipo      String
  descricao String?
  pedidoId  String?
  createdAt DateTime @default(now())
  cliente   Cliente  @relation(fields: [clienteId], references: [id])

  @@index([clienteId])
}

model ListaEspera {
  id         String   @id @default(cuid())
  produtoId  String
  email      String
  notificado Boolean  @default(false)
  createdAt  DateTime @default(now())
  produto    Produto  @relation(fields: [produtoId], references: [id])

  @@index([produtoId, notificado])
}

model PontosCliente {
  id        String   @id @default(cuid())
  clienteId String   @unique
  pontos    Int      @default(0)
  updatedAt DateTime @updatedAt
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
}

model ProdutoDestaque {
  id        String   @id @default(cuid())
  produtoId String
  ordem     Int      @default(0)
  secao     String   @default("mais-vendidos")
  createdAt DateTime @default(now())
  produto   Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([produtoId], map: "ProdutoDestaque_produtoId_fkey")
  @@index([secao])
}

model VariacaoProduto {
  id        String   @id @default(cuid())
  produtoId String
  nome      String
  sku       String   @unique
  preco     Decimal? @db.Decimal(10, 2)
  estoque   Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  produto   Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([produtoId])
}

model EmailTemplate {
  id           String   @id @default(uuid())
  tipo         String   @unique
  ativo        Boolean  @default(true)
  assunto      String
  corpo        String   @db.LongText
  prazo        Int      @default(0)
  unidadePrazo String   @default("horas")
  updatedAt    DateTime @updatedAt
}

model CookieConsent {
  id         String   @id @default(uuid())
  sessionId  String
  ip         String?
  userAgent  String?  @db.Text
  aceitou    Boolean  @default(false)
  categorias String   @default("{}")
  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model EventoAnalitico {
  id        String   @id @default(uuid())
  sessionId String
  userId    String?
  tipo      String
  dados     String   @default("{}")
  pagina    String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([tipo])
  @@index([createdAt])
}

model ClienteInsight {
  id               String   @id @default(uuid())
  sessionId        String   @unique
  userId           String?
  primeiraVisita   DateTime @default(now())
  ultimaVisita     DateTime @default(now())
  totalVisitas     Int      @default(1)
  totalPaginas     Int      @default(1)
  carrinhosAbertos Int      @default(0)
  comprasFeitas    Int      @default(0)
  totalGasto       Float    @default(0)
  produtosVistos   String   @default("[]")
  buscas           String   @default("[]")
  dispositivo      String?
  cidade           String?
  fonte            String?
  cookieCategs     String   @default("{}")

  @@index([ultimaVisita])
}

model AvaliacaoParceiro {
  id            String   @id @default(uuid())
  nomeCompleto  String
  empresa       String?
  cargo         String?
  cidade        String?
  nota          Int      @default(5)
  titulo        String
  comentario    String   @db.Text
  avatarInicial String?
  corAvatar     String   @default("#3cbfb3")
  aprovada      Boolean  @default(true)
  destaque      Boolean  @default(false)
  ordem         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("avaliacao_parceiro")
}

model CashbackTransacao {
  id        String   @id @default(cuid())
  clienteId String
  tipo      String   // "credito" | "debito"
  valor     Float
  descricao String?
  pedidoId  String?
  createdAt DateTime @default(now())
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([createdAt])
}

model BloqueioFraude {
  id        String   @id @default(cuid())
  clienteId String
  motivo    String
  criadoPor String?  // admin email
  createdAt DateTime @default(now())
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([createdAt])
}

model Campanha {
  id          String   @id @default(cuid())
  tipo        String   // 'promocional' | 'sazonal' | 'recuperacao' | 'aniversario' | 'lancamento' | 'reengajamento' | 'EMAIL' | 'WHATSAPP'
  nome        String
  assunto     String?
  mensagem    String   @db.Text
  status      String   @default("rascunho")
  agendadoPara DateTime?
  enviadaEm   DateTime?
  totalDestinatarios Int @default(0)
  totalEnviados      Int @default(0)
  totalErros         Int @default(0)
  taxaAbertura       Float @default(0)
  filtroSegmento  Json?
  whatsappNumeroId String?
  whatsappNumero   WhatsappNumero? @relation(fields: [whatsappNumeroId], references: [id])
  destinatarios    CampanhaDestinatario[]

  // Wizard fields (PR3)
  publicoAlvo       Json?
  tituloCopy        String?
  corpoCopy         String?   @db.Text
  ctaTexto          String?
  ctaUrl            String?
  produtoDestaqueId String?
  cupomId           String?
  canais            Json?
  emailAssunto      String?
  whatsappTexto     String?   @db.Text
  dataAgendamento   DateTime?
  totalAlvo         Int       @default(0)
  totalAbertos      Int       @default(0)
  totalCliques      Int       @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NivelFidelidade {
  id          String  @id @default(cuid())
  slug        String  @unique
  nome        String
  iconeUrl    String?
  iconeLucide String?
  cor         String
  gastoMin    Float
  gastoMax    Float?
  cashbackPc  Float
  ordem       Int     @default(0)
}

model CampanhaDestinatario {
  id         String    @id @default(cuid())
  campanhaId String
  campanha   Campanha  @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  clienteId  String?
  cliente    Cliente?  @relation(fields: [clienteId], references: [id])
  nome       String
  email      String?
  telefone   String?
  status     String    @default("PENDENTE")
  enviadoEm  DateTime?
  erroMsg    String?
  createdAt  DateTime  @default(now())

  @@index([campanhaId])
  @@index([clienteId])
}

model WhatsappNumero {
  id          String   @id @default(cuid())
  nome        String
  numero      String
  instanceId  String?
  apiUrl      String?
  apiKey      String?
  ativo       Boolean  @default(true)
  status      String   @default("DESCONECTADO")
  qrCode      String?  @db.Text
  ehPadrao    Boolean  @default(false)
  totalEnviados Int    @default(0)
  campanhas   Campanha[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EnvioLog {
  id         String   @id @default(cuid())
  campanhaId String?
  tipo       String
  destinatario String
  status     String
  erroMsg    String?
  createdAt  DateTime @default(now())

  @@index([campanhaId])
}

model LunaConversa {
  id                String         @id @default(cuid())
  sessaoId          String         @unique
  paginaOrigem      String?        @db.Text
  userAgent         String?        @db.Text
  ip                String?
  clienteId         String?
  status            String         @default("ativa")
  totalMensagens    Int            @default(0)
  primeiraMensagem  DateTime?
  ultimaMensagem    DateTime?
  duracaoSegundos   Int?
  leadGerado        Boolean        @default(false)
  produtoInteresse  String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  mensagens         LunaMensagem[]

  @@index([sessaoId])
  @@index([clienteId])
  @@index([createdAt])
  @@index([status])
}

model LunaMensagem {
  id          String       @id @default(cuid())
  conversaId  String
  role        String
  conteudo    String       @db.LongText
  tokens      Int?
  latenciaMs  Int?
  createdAt   DateTime     @default(now())
  conversa    LunaConversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  @@index([conversaId])
  @@index([createdAt])
}

model SessaoVisitante {
  id              String           @id @default(cuid())
  sessaoId        String           @unique
  userId          String?
  ip              String?
  pais            String?
  cidade          String?
  userAgent       String?          @db.Text
  dispositivo     String?
  browser         String?
  os              String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  referer         String?          @db.Text
  landingPage     String?          @db.Text
  totalPaginas    Int              @default(0)
  duracaoSegundos Int              @default(0)
  converteu       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  eventos         EventoTracking[]

  @@index([sessaoId])
  @@index([userId])
  @@index([createdAt])
  @@index([utmSource])
}

model EventoTracking {
  id          String          @id @default(cuid())
  sessaoId    String
  tipo        String
  pagina      String?         @db.Text
  produtoId   String?
  produtoSlug String?
  valor       Float?
  dados       Json?
  createdAt   DateTime        @default(now())
  sessao      SessaoVisitante @relation(fields: [sessaoId], references: [sessaoId], onDelete: Cascade)

  @@index([sessaoId])
  @@index([tipo])
  @@index([produtoSlug])
  @@index([createdAt])
}

model RelatorioVendaHora {
  id           String   @id @default(cuid())
  data         DateTime
  hora         Int
  diaSemana    Int
  totalPedidos Int      @default(0)
  totalReceita Float    @default(0)
  totalItens   Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([data, hora])
  @@index([data])
}
