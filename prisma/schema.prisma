generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Cliente {
  id            String     @id @default(cuid())
  nome          String
  email         String     @unique
  senha         String
  cpf           String?    @unique
  telefone      String?
  erpClienteId  String?    @unique
  createdAt     DateTime   @default(now())

  enderecos       Endereco[]
  pedidos         Pedido[]
  carrinho        Carrinho?
  avaliacoes      Avaliacao[]
  pontos          PontosCliente?
  historicoPontos HistoricoPontos[]
}

model Endereco {
  id           String   @id @default(cuid())
  clienteId    String
  cep          String
  logradouro   String
  numero       String
  complemento  String?
  bairro       String
  cidade       String
  estado       String   @db.Char(2)
  principal    Boolean  @default(false)

  cliente      Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  pedidos      Pedido[]

  @@index([clienteId])
}

model Produto {
  id               String   @id @default(cuid())
  erpProdutoId     String   @unique
  nome             String
  slug             String   @unique
  descricao        String?  @db.Text
  preco            Decimal  @db.Decimal(10, 2)
  precoPromocional Decimal? @db.Decimal(10, 2)
  imagens          Json     @default("[]")
  estoque          Int      @default(0)
  categoria        String
  modelo           String?
  sku              String?  @unique
  ativo            Boolean  @default(true)
  temVariacoes     Boolean  @default(false)
  createdAt        DateTime @default(now())

  itensPedido   ItemPedido[]
  itensCarrinho ItemCarrinho[]
  variacoes     VariacaoProduto[]
  destaques     ProdutoDestaque[]
  avaliacoes    Avaliacao[]
  listaEspera   ListaEspera[]

  @@index([categoria])
  @@index([slug])
  @@index([ativo])
}

model VariacaoProduto {
  id        String   @id @default(uuid())
  produtoId String
  produto   Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  nome      String
  sku       String   @unique
  preco     Decimal? @db.Decimal(10, 2)
  estoque   Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([produtoId])
}

model Pedido {
  id             String     @id @default(cuid())
  clienteId      String
  status         String     @default("pendente")
  total          Decimal    @db.Decimal(10, 2)
  frete          Decimal    @db.Decimal(10, 2)
  desconto       Decimal    @default(0) @db.Decimal(10, 2)
  cupomCodigo    String?
  formaPagamento String
  mpPaymentId    String?
  codigoRastreio String?
  enderecoId     String
  erpPedidoId    String?    @unique
  createdAt      DateTime   @default(now())

  cliente  Cliente    @relation(fields: [clienteId], references: [id])
  endereco Endereco   @relation(fields: [enderecoId], references: [id])
  itens    ItemPedido[]

  @@index([clienteId])
  @@index([status])
}

model ItemPedido {
  id             String   @id @default(cuid())
  pedidoId       String
  produtoId      String
  quantidade     Int
  precoUnitario  Decimal  @db.Decimal(10, 2)
  variacaoId     String?
  variacaoNome   String?

  pedido         Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto        Produto  @relation(fields: [produtoId], references: [id])

  @@index([pedidoId])
}

model Carrinho {
  id        String   @id @default(cuid())
  clienteId String?  @unique
  sessionId String?  @unique
  createdAt DateTime @default(now())

  cliente   Cliente?       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  itens     ItemCarrinho[]

  @@index([sessionId])
}

model ItemCarrinho {
  id         String  @id @default(cuid())
  carrinhoId String
  produtoId  String
  quantidade Int

  carrinho   Carrinho @relation(fields: [carrinhoId], references: [id], onDelete: Cascade)
  produto    Produto  @relation(fields: [produtoId], references: [id])

  @@unique([carrinhoId, produtoId])
}

model Configuracao {
  id        String   @id @default(uuid())
  chave     String   @unique
  valor     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Banner {
  id        String   @id @default(uuid())
  imagem    String
  titulo    String?
  subtitulo String?
  link      String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  tempoCads Int      @default(5)
  createdAt DateTime @default(now())
}

model ProdutoDestaque {
  id        String   @id @default(uuid())
  produtoId String
  produto   Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  ordem     Int      @default(0)
  secao     String   @default("mais-vendidos")
  createdAt DateTime @default(now())

  @@index([secao])
}

model Avaliacao {
  id         String   @id @default(uuid())
  produtoId  String
  produto    Produto  @relation(fields: [produtoId], references: [id])
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
  nota       Int
  titulo     String?
  comentario String?  @db.Text
  aprovada   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([produtoId, aprovada])
}

model Cupom {
  id          String    @id @default(uuid())
  codigo      String    @unique
  tipo        String    @default("percentual")
  valor       Decimal   @db.Decimal(10, 2)
  usoMaximo   Int?
  usoAtual    Int       @default(0)
  valorMinimo Decimal?  @db.Decimal(10, 2)
  expiresAt   DateTime?
  ativo       Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model PontosCliente {
  id        String   @id @default(uuid())
  clienteId String   @unique
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  pontos    Int      @default(0)
  updatedAt DateTime @updatedAt
}

model HistoricoPontos {
  id        String   @id @default(uuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  pontos    Int
  tipo      String
  descricao String?
  pedidoId  String?
  createdAt DateTime @default(now())

  @@index([clienteId])
}

model ListaEspera {
  id         String   @id @default(uuid())
  produtoId  String
  produto    Produto  @relation(fields: [produtoId], references: [id])
  email      String
  notificado Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([produtoId, notificado])
}
