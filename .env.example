# Database
DATABASE_URL="mysql://user:pass@host:port/db"

# NextAuth
NEXTAUTH_SECRET="replace-me-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Admin security (Sprint 1)
# Gere o hash com: node -e "require('bcryptjs').hash('SUA_SENHA_FORTE', 12).then(console.log)"
ADMIN_PASSWORD_HASH="$2b$12$replace-with-real-hash"
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="replace-with-48-bytes-base64"
# Sufixo da URL admin (rota física em src/app/adm-a7f9c2b4/)
ADMIN_PATH_TOKEN="adm-a7f9c2b4"
# Path PÚBLICO do admin, configurável (rotação). O proxy reescreve este path para
# a rota física interna /adm-a7f9c2b4 e responde 404 no path interno quando este
# difere. Precisa ser NEXT_PUBLIC_ (build-time) porque os links são client-side.
# Vazio/ausente → usa o default 'adm-a7f9c2b4' e nada muda. Trocar exige redeploy.
NEXT_PUBLIC_ADMIN_PATH="adm-a7f9c2b4"

# Mercado Pago
NEXT_PUBLIC_MP_PUBLIC_KEY=""
MP_ACCESS_TOKEN=""

# Focus NFe
FOCUS_NFE_TOKEN=""
FOCUS_NFE_ENV="homologacao"

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Analytics — Meta Pixel (Facebook/Instagram Ads)
# Vazio/ausente → Pixel não carrega (guard no MetaPixelScript). NÃO instalar o
# Pixel também via GTM (evento dobrado). Dispara nos mesmos pontos do GA4.
NEXT_PUBLIC_META_PIXEL_ID="263518239869895"

# E-mail transacional (Resend)
# Sem RESEND_API_KEY o envio degrada graciosamente: loga e não quebra o fluxo.
# EMAIL_FROM precisa ser de um domínio verificado no Resend.
RESEND_API_KEY=""
EMAIL_FROM="noreply@sixxis.com.br"
EMAIL_FROM_NAME="Sixxis"

# ERP
ERP_API_URL="http://localhost:3001"
ERP_API_SECRET=""

# Melhor Envio
MELHOR_ENVIO_TOKEN=""

# Cloudflare R2
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Gateway (Sprint 2) — chaves de API dos sistemas externos
ERP_API_KEY="replace-me"
NFE_API_KEY="replace-me"
WEBHOOK_API_KEY="replace-me"

# Cloudflare Turnstile (anti-bot) — DEGRADAÇÃO GRACIOSA: sem estas vars o widget
# não renderiza e o servidor não verifica (login/cadastro seguem normais).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Upstash Redis (rate-limit) — DEGRADAÇÃO GRACIOSA: sem estas vars o rate-limit
# é desligado (nenhuma rota é bloqueada).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# API interna para o CRM (ponte CRM<->loja). Header x-internal-key.
# Gere uma chave forte: openssl rand -hex 32
STORE_INTERNAL_KEY=""
