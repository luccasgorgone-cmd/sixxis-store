# Database
DATABASE_URL="mysql://user:pass@host:port/db"

# NextAuth
NEXTAUTH_SECRET="replace-me-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Admin security (Sprint 1)
# Gere o hash com: node -e "require('bcryptjs').hash('SUA_SENHA_FORTE', 12).then(console.log)"
ADMIN_PASSWORD_HASH="$2b$12$replace-with-real-hash"
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="replace-with-48-bytes-base64"
# Sufixo da URL admin (rota física em src/app/adm-a7f9c2b4/)
ADMIN_PATH_TOKEN="adm-a7f9c2b4"

# Mercado Pago
NEXT_PUBLIC_MP_PUBLIC_KEY=""
